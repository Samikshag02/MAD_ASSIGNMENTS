<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 🔹 Header Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back,"
                    android:textSize="16sp"
                    android:textColor="#5C6BC0"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/tvNameTop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E" />
            </LinearLayout>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivProfile"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/profile"
                app:civ_border_width="3dp"
                app:civ_border_color="#FFFFFF"
                android:elevation="4dp"/>
        </RelativeLayout>

        <!-- 🔹 Personal Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Profile"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#3F51B5"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        app:tint="#757575"/>
                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="user@example.com"
                        android:textSize="14sp"
                        android:textColor="#424242"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_group"
                        app:tint="#757575"/>
                    <TextView
                        android:id="@+id/tvBranch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Computer Engineering"
                        android:textSize="14sp"
                        android:textColor="#424242"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvYear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Year: 3rd"
                        android:textSize="14sp"
                        android:textColor="#616161"
                        android:background="#F5F5F5"
                        android:padding="8dp"
                        android:gravity="center"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/tvDivision"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Div: A"
                        android:textSize="14sp"
                        android:textColor="#616161"
                        android:background="#F5F5F5"
                        android:padding="8dp"
                        android:gravity="center"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSkills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Skills: Android, Java, Firebase"
                    android:textSize="14sp"
                    android:textColor="#1A237E"
                    android:background="#E8EAF6"
                    android:padding="10dp"
                    android:layout_marginTop="12dp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🔹 Current Project Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="24dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Project"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#2196F3"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvProjectTitleHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Project Title"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvProjectDescHome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description goes here. Briefly explaining the project goal."
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvProjectRolesHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roles: Designer, Developer"
                    android:textSize="13sp"
                    android:textColor="#3F51B5"
                    android:textStyle="italic"
                    android:background="#E1F5FE"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🔹 Quick Actions Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Navigation"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="16dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindUsers"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Explore Users"
                app:cornerRadius="12dp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFF"
                android:textAllCaps="false"
                android:padding="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRequests"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Incoming"
                app:cornerRadius="12dp"
                android:backgroundTint="#673AB7"
                android:textColor="#FFF"
                android:textAllCaps="false"
                android:padding="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnections"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Connections"
                app:cornerRadius="12dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFF"
                android:textAllCaps="false"
                android:padding="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSent"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Sent"
                app:cornerRadius="12dp"
                android:backgroundTint="#FFA726"
                android:textColor="#FFF"
                android:textAllCaps="false"
                android:padding="12dp"/>
        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProject"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Project Details"
            app:cornerRadius="12dp"
            android:textColor="#3F51B5"
            app:strokeColor="#3F51B5"
            app:strokeWidth="1.5dp"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            app:cornerRadius="12dp"
            android:backgroundTint="#FF5252"
            android:textColor="#FFF"
            android:padding="14dp"
            android:textAllCaps="false"
            android:layout_marginBottom="20dp" />

    </LinearLayout>
</ScrollView>
